node_modules/

# Build output — produced by `pnpm build` (tsup), built in CI, never committed
dist/

# Generated benchmark fixtures — regenerate with `pnpm gen:fixtures`
bench/fixtures/data/

# Vendored yaml-test-suite snapshot — regenerate with `pnpm gen:suite`
bench/yaml-test-suite/data/

# Bundled browser harness (esbuild output + derived fixture manifest) — regenerate with `pnpm bench:browser`
bench/browser/generated/

# Benchmark output
results/
*.log

# Local calibration/scratch scripts (not part of the committed harness) —
# also holds /code-review's per-reviewer `.scratch/code_review_*.md` notes
.scratch/
*.scratch.*

# Transient subagent worktrees created by the Claude Code harness
.claude/worktrees/
