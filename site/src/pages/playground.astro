---
// /playground — the dedicated full-width home for the interactive comparison +
// benchmark widget. The widget itself is the shared <Playground /> component
// (also inlined on the homepage), so behaviour and look stay in one place (DRY).
// This page only supplies the surrounding chrome: a dark shell + top nav, and
// tells the widget to run immediately (visitors came here to use it).
//
// Standalone route (not the Starlight docs layout) so it owns the full width.
import Playground from '../components/Playground.astro';
const title = 'Playground — Lightning YAML';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta
      name="description"
      content="Paste YAML or JSON and see how lightning-yaml, yaml, and js-yaml parse and dump it — side by side, in your browser, with timings and a structural diff when they disagree."
    />
    <link rel="icon" href="/favicon.svg" />
    <style is:global>
      :root {
        --ly-void: #0b0d14;
        --ly-panel: #141824;
        --ly-panel-2: #10131d;
        --ly-line: #232a3b;
        --ly-ink: #e8ecf6;
        --ly-muted: #9aa4bc;
        --ly-charge: #7c5cff;
        --ly-spark: #35e0d8;
        --ly-amber: #ffb020;
        --sl-font: Inter, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
        --sl-font-mono: 'IBM Plex Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
      }
      * { box-sizing: border-box; }
      html, body { min-height: 100%; }
      body {
        margin: 0;
        background:
          radial-gradient(60% 40% at 20% -5%, rgba(124, 92, 255, 0.14), transparent 60%),
          var(--ly-void);
        color: var(--ly-ink);
        font-family: var(--sl-font);
        -webkit-font-smoothing: antialiased;
      }
      a { color: var(--ly-spark); }

      .pg-top {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 0.9rem clamp(1rem, 3vw, 2rem);
        border-bottom: 1px solid var(--ly-line);
      }
      .pg-top__brand {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        font-weight: 600;
        color: var(--ly-ink);
        text-decoration: none;
        letter-spacing: -0.01em;
      }
      .pg-top__brand b { color: var(--ly-charge); }
      .pg-top__links { margin-inline-start: auto; display: flex; gap: 1.1rem; font-size: 0.86rem; font-family: var(--sl-font-mono); }
      .pg-top__links a { color: var(--ly-muted); text-decoration: none; }
      .pg-top__links a:hover { color: var(--ly-ink); }

      .pg-main {
        max-width: 1140px;
        margin: 0 auto;
        padding: clamp(1.25rem, 4vw, 2.5rem) clamp(1rem, 3vw, 2rem) 4rem;
      }
      :focus-visible { outline: 2px solid var(--ly-spark); outline-offset: 2px; border-radius: 6px; }
    </style>
  </head>
  <body>
    <header class="pg-top">
      <a class="pg-top__brand" href="/"><b>⚡</b> lightning-yaml</a>
      <nav class="pg-top__links">
        <a href="/guides/getting-started/">Docs</a>
        <a href="/benchmarks/">Benchmarks</a>
        <a href="https://github.com/jbsiddall/lightning-yaml">GitHub</a>
      </nav>
    </header>

    <main class="pg-main">
      <Playground autorun="immediate" />
    </main>
  </body>
</html>
