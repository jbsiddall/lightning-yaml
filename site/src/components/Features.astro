---
// Features.astro — terse capability strip. Static, no client JS.
const features = [
  'Anchors, aliases, !!binary & multi-doc streams',
  'parse · parseAll · stringify',
  'js-yaml / yaml drop-in shims',
  'TypeScript-first types',
  'Zero dependencies',
];
---

<section class="features" aria-label="Capabilities">
  <ul class="features__list">
    {features.map((f) => (
      <li class="chip">
        <span class="chip__spark" aria-hidden="true"></span>
        <span class="chip__text">{f}</span>
      </li>
    ))}
  </ul>

  <p class="features__note">
    <b>Drop-in is API-level today.</b> Imports and call signatures match
    <code>js-yaml</code> and <code>yaml</code>, so existing code runs — but an
    option argument we don't yet honour (<code>schema</code>, <code>sortKeys</code>, <code>indent</code>, …)
    <b>throws</b> rather than silently changing your output. Useful for migrating
    now; not yet a 1:1 behavioural match.
  </p>
</section>

<style>
  .features {
    width: 100%;
  }
  .features__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    justify-content: center;
  }

  .chip {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.5rem 0.9rem;
    border: 1px solid var(--ly-line);
    border-radius: 999px;
    background: var(--ly-panel);
    color: var(--ly-ink);
    font-family: var(--sl-font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.01em;
  }

  .chip__spark {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--ly-spark);
    box-shadow: 0 0 8px var(--ly-spark-glow);
    flex: none;
  }

  .features__note {
    margin: 0.9rem auto 0;
    max-width: 66ch;
    text-align: center;
    color: var(--ly-muted);
    font-size: 0.78rem;
    line-height: 1.55;
  }
  .features__note b {
    color: var(--ly-ink);
    font-weight: 600;
  }
  .features__note code {
    font-family: var(--sl-font-mono);
    font-size: 0.92em;
    color: var(--ly-ink);
    background: rgba(124, 92, 255, 0.12);
    border: 1px solid var(--ly-line);
    border-radius: 5px;
    padding: 0.03em 0.32em;
  }
</style>
