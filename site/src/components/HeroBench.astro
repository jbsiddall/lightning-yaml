---
// HeroBench.astro — the hero's right-hand instrument: a four-tab benchmark
// panel (Parse / Dump / Parse memory / Bundle size), Bun-homepage style.
// CSS-only tab switching via sibling radio inputs — zero client JS. Every bar
// is computed at BUILD TIME from the published runs in
// src/data/benchmarks/*.yaml (overlaid from the benchmark-data branch at
// deploy), so the numbers here are the same measured data the /benchmarks page
// shows — never a hand-typed figure. See CLAUDE.md "Integrity of benchmarks".
//
// Parse/Dump/Memory show RATIOS against lightning-yaml (always 1.0×), not
// absolute times — the one exception is Bundle size, which stays absolute KB
// because it's deterministic and environment-free. Every ratio is the
// CANONICAL environment's own measured ratio (canonicalRun — a real browser
// engine once one publishes, falling back to Node; see queries.ts's
// "Ratio queries" section) — ONE real measurement, never blended across
// environments. Click a ratio to open its native-Popover-API breakdown:
// every environment's own ratio, listed separately, built at BUILD TIME,
// zero client JS. Each row still scales to its own largest bar, clipping an
// outlier that runs away from the field (>3× the runner-up, "off-scale" ↗)
// so the rest stay legible.
import speedRaw from '../data/benchmarks/speed.yaml?raw';
import memoryRaw from '../data/benchmarks/memory.yaml?raw';
import bundleSizeRaw from '../data/benchmarks/bundle-size.yaml?raw';
import {
  parseRuns,
  newestOf,
  newestRun,
  canonicalRun,
  pickWorkloads,
  bundleSizeItems,
  speedWorkloadRatio,
  memoryWorkloadRatio,
  canonicalSpeedRatio,
  canonicalMemoryRatio,
  SpeedDocSchema,
  MemoryDocSchema,
  BundleSizeDocSchema,
} from '../lib/queries';
import type { LibraryId } from '../lib/queries';
import { buildChart, ratioBarRows, libraryLabel } from '../lib/charts';
import type { RatioRow } from '../lib/charts';

const speedRuns = parseRuns(speedRaw, SpeedDocSchema);
const speed = canonicalRun(speedRuns);
const memoryRuns = parseRuns(memoryRaw, MemoryDocSchema);
const memory = newestOf(memoryRuns);
const bundle = newestRun(bundleSizeRaw, BundleSizeDocSchema);

const HERO_ORDER: LibraryId[] = ['JSON', 'lightning-yaml', 'js-yaml', 'yaml'];

// The speed tabs chart the block-YAML config fixtures: real-world YAML is
// overwhelmingly block-style config (see the 2026-07-16 target-workload research
// note), and the JSON-text fixtures — where our lead over js-yaml happens to be
// larger — would flatter us. Memory keeps the JSON trio for the 10 MB tail case
// (YAML fixtures are capped at 1 MB by design).
const speedNames = ['yaml-plain-small-records', 'yaml-plain-medium-records', 'yaml-plain-large-records'];
const memoryNames = ['small-records', 'large-records', 'xlarge-records'];
const WORKLOAD_LABEL: Record<string, string> = {
  'yaml-plain-small-records': 'small config · ~1 KB',
  'yaml-plain-medium-records': 'medium config · ~100 KB',
  'yaml-plain-large-records': 'large config · ~1 MB',
};

function speedRatioRows(op: 'parse' | 'stringify', names: string[]): RatioRow[] {
  return pickWorkloads(speed.operations[op], names).map((w) => ({
    name: WORKLOAD_LABEL[w.workload] ?? w.workload,
    ratios: Object.fromEntries(
      HERO_ORDER.map((id) => [id, canonicalSpeedRatio(speedRuns, op, w.workload, id, 'lightning-yaml')]),
    ) as Partial<Record<LibraryId, number>>,
    points: Object.fromEntries(
      HERO_ORDER.map((id) => [id, speedWorkloadRatio(speedRuns, op, w.workload, id, 'lightning-yaml')]),
    ) as RatioRow['points'],
  }));
}
function memoryRatioRows(names: string[]): RatioRow[] {
  return pickWorkloads(memory.operations.parse, names).map((w) => ({
    name: w.workload,
    ratios: Object.fromEntries(
      HERO_ORDER.map((id) => [id, canonicalMemoryRatio(memoryRuns, 'parse', w.workload, id, 'lightning-yaml')]),
    ) as Partial<Record<LibraryId, number>>,
    points: Object.fromEntries(
      HERO_ORDER.map((id) => [id, memoryWorkloadRatio(memoryRuns, 'parse', w.workload, id, 'lightning-yaml')]),
    ) as RatioRow['points'],
  }));
}

const speedTitleFor = (rowName: string, id: LibraryId) =>
  `${libraryLabel(speed.libraries, id)} ÷ ${libraryLabel(speed.libraries, 'lightning-yaml')} — ${rowName}`;
const memoryTitleFor = (rowName: string, id: LibraryId) =>
  `${libraryLabel(memory.libraries, id)} ÷ ${libraryLabel(memory.libraries, 'lightning-yaml')} — ${rowName} (peak RSS)`;

// Off-scale clamping (>3× the runner-up gets clipped, ↗) mirrors the old
// per-unit behaviour: speed rows clamp, memory rows never did.
const parseChart = ratioBarRows(speedRatioRows('parse', speedNames), HERO_ORDER, 'hero-parse', speedTitleFor, true);
const dumpChart = ratioBarRows(speedRatioRows('stringify', speedNames), HERO_ORDER, 'hero-dump', speedTitleFor, true);
const memoryChart = ratioBarRows(memoryRatioRows(memoryNames), HERO_ORDER, 'hero-mem', memoryTitleFor, false);

const bundleValues = Object.fromEntries(bundleSizeItems(bundle).map((it) => [it.id, it.value]));
const bundleChart = buildChart([{ name: 'min + gzip', values: bundleValues }], 'bytes', HERO_ORDER);

const tabs = [
  {
    id: 'parse',
    label: 'Parse speed',
    caption: 'Time to parse() block-YAML config, relative to Lightning YAML (always 1.0×) — the shape most real-world YAML takes. Scaled to the runner-up; yaml runs off-scale (↗). JSON.parse sits out: it can’t read block YAML. Click a ratio for per-engine results.',
    chart: parseChart,
  },
  {
    id: 'dump',
    label: 'Dump speed',
    caption: 'Time to stringify() the same parsed config, relative to Lightning YAML (always 1.0×) — JSON.stringify included as a baseline on the same value. Click a ratio for per-engine results.',
    chart: dumpChart,
  },
  {
    id: 'memory',
    label: 'Parse memory',
    caption: 'Peak resident set size while parsing (25 iterations), relative to Lightning YAML (always 1.0×) — lower is better. Click a ratio for per-engine results.',
    chart: memoryChart,
  },
  {
    id: 'bundle',
    label: 'Bundle size',
    caption: 'Browser bundle (parse + stringify), min + gzip — smallest across every bundler measured. Deterministic and environment-free, so this tab stays absolute.',
    chart: bundleChart,
  },
];

// Versions must come from the measured run's own metadata — reading them from a
// package.json shows whatever the site happens to install, not what was benched
// (that's how the footer once claimed js-yaml 4.1.0 while the data measured 5.2.1).
const libVersion = (id: LibraryId) => speed.libraries.find((l) => l.id === id)?.version ?? '?';
const lyVersion = speed.libraries.find((l) => l.self)?.version ?? '?';
const versions = `lightning-yaml ${lyVersion} · yaml ${libVersion('yaml')} · js-yaml ${libVersion('js-yaml')}`;
---

<figure class="hb" aria-label="Benchmarks: Lightning YAML versus js-yaml, yaml, and JSON">
  <figcaption class="hb__head">
    <span class="hb__title">How fast?</span>
    <span class="hb__sub">measured, not marketing</span>
  </figcaption>

  {tabs.map((t, i) => (
    <input class="hb__radio" type="radio" name="hb-tab" id={`hb-tab-${t.id}`} checked={i === 0} />
  ))}

  <div class="hb__tabs" role="tablist">
    {tabs.map((t) => (
      <label class="hb__tab" for={`hb-tab-${t.id}`}>{t.label}</label>
    ))}
  </div>

  {tabs.map((t) => (
    <section class="hb__panel" data-tab={t.id} aria-label={t.label}>
      <p class="hb__cap">{t.caption}</p>
      {t.chart.map((g) => (
        <div class="grp">
          <div class="grp__head">{g.name}</div>
          {g.bars.map((b) => (
            <div class:list={['barline', { 'barline--self': b.self, 'barline--over': b.over }]}>
              <span class="barline__lib" style={`color:${b.color}`}>{b.id}</span>
              <span class="barline__track"><span class="barline__bar" style={`width:${b.width}%;background:${b.color}`}></span></span>
              {b.popoverId ? (
                <button type="button" class="barline__val ratio-btn" popovertarget={b.popoverId} aria-label={`${b.label} — click for per-engine results`}>
                  {b.label}{b.over && <span class="over-mark">↗</span>}
                </button>
              ) : (
                <span class="barline__val">{b.label}{b.over && <span class="over-mark">↗</span>}</span>
              )}
            </div>
          ))}
          {g.bars.map((b) =>
            b.popoverId && b.popoverHtml ? <div id={b.popoverId} popover="auto" class="ratio-pop" set:html={b.popoverHtml} /> : null,
          )}
        </div>
      ))}
    </section>
  ))}

  <div class="hb__foot">
    <span class="hb__env">
      Measured in {speed.env.runtime} · benchmark-data branch<br />
      <span class="hb__vers">{versions}</span>
    </span>
    <a class="hb__more" href="/benchmarks/">Full benchmarks&nbsp;→</a>
  </div>
</figure>

<style>
  .hb {
    margin: 0;
    display: flex;
    flex-direction: column;
    border: 1px solid var(--ly-line);
    border-radius: 16px;
    background:
      radial-gradient(80% 60% at 100% 0%, rgba(53, 224, 216, 0.07), transparent 60%),
      linear-gradient(180deg, #0f1320, #0b0d14 70%);
    box-shadow: 0 30px 70px -46px rgba(0, 0, 0, 0.95);
    overflow: hidden;
  }

  .hb__head { display: flex; align-items: baseline; gap: 0.6rem; padding: 0.85rem 1.1rem 0.6rem; flex-wrap: wrap; }
  .hb__title { font-family: var(--sl-font); font-weight: 600; font-size: 1rem; color: var(--ly-ink); }
  .hb__sub { margin-inline-start: auto; font-family: var(--sl-font-mono); font-size: 0.66rem; color: var(--ly-muted); opacity: 0.8; }

  .hb__radio { position: absolute; width: 1px; height: 1px; opacity: 0; pointer-events: none; }

  .hb__tabs { display: flex; gap: 0.15rem; padding: 0 1.1rem; border-bottom: 1px solid var(--ly-line); overflow-x: auto; }
  .hb__tab {
    flex: none; padding: 0.5rem 0.7rem; margin-bottom: -1px;
    font-family: var(--sl-font-mono); font-size: 0.78rem; color: var(--ly-muted);
    border-bottom: 2px solid transparent; cursor: pointer; user-select: none; white-space: nowrap;
    transition: color 0.15s ease, border-color 0.15s ease;
  }
  .hb__tab:hover { color: var(--ly-ink); }

  .hb__panel { display: none; padding: 0.9rem 1.1rem 0.4rem; }
  .hb__cap { margin: 0 0 0.85rem; font-family: var(--sl-font-mono); font-size: 0.68rem; line-height: 1.5; color: var(--ly-muted); }

  .grp { margin-bottom: 0.95rem; }
  .grp__head { font-family: var(--sl-font-mono); font-size: 0.7rem; color: var(--ly-muted); margin-bottom: 0.32rem; letter-spacing: 0.02em; }
  .barline { display: grid; grid-template-columns: 92px 1fr 82px; align-items: center; gap: 0.5rem; height: 20px; }
  .barline__lib { font-family: var(--sl-font-mono); font-size: 0.7rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .barline__track { height: 9px; background: rgba(255, 255, 255, 0.045); border-radius: 5px; overflow: hidden; }
  .barline__bar { display: block; height: 100%; border-radius: 5px; }
  .barline--self .barline__bar { box-shadow: 0 0 10px var(--ly-charge-glow); }
  .barline--self .barline__lib { font-weight: 600; }
  .barline--self .barline__val { color: var(--ly-ink); font-weight: 600; }
  .barline__val { font-family: var(--sl-font-mono); font-size: 0.68rem; color: var(--ly-muted); text-align: right; font-variant-numeric: tabular-nums; white-space: nowrap; }
  /* Off-scale bar: cannot be contained — no rounded/solid right edge, it fades
     out past the runner-up, and the value carries a ↗ marker. */
  .barline--over .barline__track { overflow: visible; }
  .barline--over .barline__bar {
    border-top-right-radius: 0;
    border-bottom-right-radius: 0;
    -webkit-mask-image: linear-gradient(90deg, #000 88%, transparent);
    mask-image: linear-gradient(90deg, #000 88%, transparent);
  }
  .over-mark { color: var(--ly-amber); margin-inline-start: 0.2rem; }

  /* Ratio bars with an inspectable breakdown render their value as a real
     <button popovertarget=...> instead of a plain <span> — dotted underline
     signals "click me" without looking like a generic form control. */
  .ratio-btn {
    all: unset;
    cursor: pointer;
    font-family: var(--sl-font-mono);
    font-size: 0.68rem;
    color: var(--ly-muted);
    text-align: right;
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
    text-decoration-line: underline;
    text-decoration-style: dotted;
    text-decoration-color: currentColor;
    text-underline-offset: 3px;
  }
  .ratio-btn:hover { color: var(--ly-ink); }
  .ratio-btn:focus-visible { outline: 2px solid var(--ly-spark); outline-offset: 2px; border-radius: 3px; }
  .barline--self .ratio-btn { color: var(--ly-ink); font-weight: 600; }

  /* Native Popover API: `showPopover()`/light-dismiss/Esc are all free from
     the `popover` attribute — this only styles the panel + its ::backdrop.
     Content (per-engine rows) is built at BUILD TIME by ratioPopoverHtml()
     in src/lib/charts.ts. */
  .ratio-pop {
    max-width: min(320px, calc(100vw - 2rem));
    margin: auto;
    padding: 0.7rem 0.85rem 0.75rem;
    border: 1px solid var(--ly-line);
    border-radius: 10px;
    background: var(--ly-panel);
    color: var(--ly-ink);
    font-family: var(--sl-font-mono);
    font-size: 0.72rem;
    line-height: 1.5;
    box-shadow: 0 24px 60px -24px rgba(0, 0, 0, 0.95);
  }
  .ratio-pop::backdrop { background: rgba(5, 7, 12, 0.55); }
  .ratio-pop__title { font-weight: 600; color: var(--ly-ink); margin: 0 0 0.3rem; }
  .ratio-pop__sub { color: var(--ly-muted); font-size: 0.9em; margin: 0 0 0.5rem; letter-spacing: 0.02em; }
  .ratio-pop__list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.28rem; }
  .ratio-pop__list li { display: flex; justify-content: space-between; gap: 0.9rem; color: var(--ly-muted); }
  .ratio-pop__env { overflow-wrap: anywhere; }
  .ratio-pop__val { color: var(--ly-ink); font-variant-numeric: tabular-nums; white-space: nowrap; }

  .hb__foot {
    display: flex; justify-content: space-between; gap: 0.6rem; flex-wrap: wrap;
    padding: 0.7rem 1.1rem 0.95rem; border-top: 1px solid var(--ly-line); margin-top: 0.4rem;
    font-family: var(--sl-font-mono); font-size: 0.68rem;
  }
  .hb__env { color: var(--ly-muted); opacity: 0.85; line-height: 1.5; }
  .hb__vers { opacity: 0.75; }
  .hb__more { color: var(--ly-spark); font-weight: 600; text-decoration: none; white-space: nowrap; }
  .hb__more:hover { color: var(--ly-ink); }

  /* CSS-only tab switching: radios are earlier siblings of the tabs + panels. */
  #hb-tab-parse:checked ~ .hb__panel[data-tab='parse'],
  #hb-tab-dump:checked ~ .hb__panel[data-tab='dump'],
  #hb-tab-memory:checked ~ .hb__panel[data-tab='memory'],
  #hb-tab-bundle:checked ~ .hb__panel[data-tab='bundle'] {
    display: block;
  }
  #hb-tab-parse:checked ~ .hb__tabs label[for='hb-tab-parse'],
  #hb-tab-dump:checked ~ .hb__tabs label[for='hb-tab-dump'],
  #hb-tab-memory:checked ~ .hb__tabs label[for='hb-tab-memory'],
  #hb-tab-bundle:checked ~ .hb__tabs label[for='hb-tab-bundle'] {
    color: var(--ly-ink);
    border-bottom-color: var(--ly-charge);
  }
  #hb-tab-parse:focus-visible ~ .hb__tabs label[for='hb-tab-parse'],
  #hb-tab-dump:focus-visible ~ .hb__tabs label[for='hb-tab-dump'],
  #hb-tab-memory:focus-visible ~ .hb__tabs label[for='hb-tab-memory'],
  #hb-tab-bundle:focus-visible ~ .hb__tabs label[for='hb-tab-bundle'] {
    outline: 2px solid var(--ly-spark);
    outline-offset: 2px;
    border-radius: 6px;
  }
</style>
