---
// ParseTrace.astro — the "parse-trace" hero signature.
// Shows the library literally doing its job: a YAML input panel, an electric
// bolt, and the parsed JS value on the output panel. Pure HTML + inline SVG,
// zero client JS. Token colouring: keys = ink, strings = spark, numbers =
// amber, punctuation = muted.
---

<div class="trace" role="img" aria-label="Lightning YAML parses a YAML document into a JavaScript object in microseconds.">
  <!-- INPUT ------------------------------------------------------------- -->
  <figure class="panel panel--in">
    <figcaption class="panel__bar">
      <span class="panel__dot" aria-hidden="true"></span>
      <span class="panel__name">config.yaml</span>
      <span class="panel__lang">YAML</span>
    </figcaption>
    <pre class="code" aria-hidden="false"><code><span class="k">server</span><span class="p">:</span>
  <span class="k">host</span><span class="p">:</span> <span class="s">0.0.0.0</span>
  <span class="k">port</span><span class="p">:</span> <span class="n">8080</span>
<span class="k">features</span><span class="p">:</span> <span class="p">[</span><span class="s">fast</span><span class="p">,</span> <span class="s">correct</span><span class="p">]</span></code></pre>
  </figure>

  <!-- BOLT -------------------------------------------------------------- -->
  <div class="bolt" aria-hidden="true">
    <div class="bolt__glow"></div>
    <svg class="bolt__svg" viewBox="0 0 24 24" width="60" height="60" fill="none" role="presentation">
      <path
        d="M13 2 L4 14 h6 l-1 8 9-12 h-6 l1-8 z"
        fill="var(--ly-charge)"
        stroke="var(--ly-charge)"
        stroke-width="0.75"
        stroke-linejoin="round"
      />
    </svg>
    <span class="bolt__readout">parsed in <b>2.9&thinsp;µs</b></span>
  </div>

  <!-- OUTPUT ------------------------------------------------------------ -->
  <figure class="panel panel--out">
    <figcaption class="panel__bar">
      <span class="panel__dot panel__dot--out" aria-hidden="true"></span>
      <span class="panel__name">parse(config)</span>
      <span class="panel__lang">JS</span>
    </figcaption>
    <pre class="code"><code><span class="p">&#123;</span>
  <span class="k">server</span><span class="p">:</span> <span class="p">&#123;</span> <span class="k">host</span><span class="p">:</span> <span class="s">"0.0.0.0"</span><span class="p">,</span> <span class="k">port</span><span class="p">:</span> <span class="n">8080</span> <span class="p">&#125;</span><span class="p">,</span>
  <span class="k">features</span><span class="p">:</span> <span class="p">[</span><span class="s">"fast"</span><span class="p">,</span> <span class="s">"correct"</span><span class="p">]</span>
<span class="p">&#125;</span></code></pre>
  </figure>
</div>

<style>
  .trace {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: clamp(0.75rem, 2.5vw, 1.75rem);
    width: 100%;
  }

  /* --- Panels --------------------------------------------------------- */
  .panel {
    position: relative;
    margin: 0;
    border: 1px solid var(--ly-line);
    border-radius: 12px;
    background:
      radial-gradient(120% 100% at 0% 0%, rgba(124, 92, 255, 0.06), transparent 55%),
      var(--ly-panel);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.03),
      inset 0 0 40px rgba(124, 92, 255, 0.04),
      0 18px 40px -24px rgba(0, 0, 0, 0.9);
    overflow: hidden;
    min-width: 0;
  }

  .panel--out {
    background:
      radial-gradient(120% 100% at 100% 0%, rgba(53, 224, 216, 0.06), transparent 55%),
      var(--ly-panel);
  }

  .panel__bar {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.8rem;
    border-bottom: 1px solid var(--ly-line);
    background: var(--ly-panel-2);
    font-family: var(--sl-font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.02em;
  }

  .panel__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--ly-charge);
    box-shadow: 0 0 8px var(--ly-charge-glow);
    flex: none;
  }
  .panel__dot--out {
    background: var(--ly-spark);
    box-shadow: 0 0 8px var(--ly-spark-glow);
  }

  .panel__name {
    color: var(--ly-muted);
  }
  .panel__lang {
    margin-inline-start: auto;
    color: var(--ly-muted);
    opacity: 0.7;
    font-size: 0.62rem;
    letter-spacing: 0.14em;
  }

  .code {
    margin: 0;
    padding: 1rem 1.1rem;
    background: transparent;
    border: 0;
    font-family: var(--sl-font-mono);
    font-size: clamp(0.78rem, 1.4vw, 0.9rem);
    line-height: 1.75;
    color: var(--ly-ink);
    overflow-x: auto;
    tab-size: 2;
  }
  .code code {
    font-family: inherit;
    background: none;
    padding: 0;
    border: 0;
    color: inherit;
    white-space: pre;
  }

  /* Token colours */
  .code .k { color: var(--ly-ink); }
  .code .s { color: var(--ly-spark); }
  .code .n { color: var(--ly-amber); }
  .code .p { color: var(--ly-muted); }

  /* --- Bolt ----------------------------------------------------------- */
  .bolt {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.25rem;
    isolation: isolate;
  }

  .bolt__glow {
    position: absolute;
    inset: 50% auto auto 50%;
    width: 120px;
    height: 120px;
    transform: translate(-50%, -50%);
    background: radial-gradient(circle, var(--ly-charge-glow), transparent 68%);
    filter: blur(6px);
    opacity: 0.7;
    z-index: -1;
    pointer-events: none;
  }

  .bolt__svg {
    transform: rotate(-90deg); /* desktop: point input -> output (rightward) */
    filter:
      drop-shadow(0 0 6px var(--ly-charge-glow))
      drop-shadow(0 0 16px rgba(124, 92, 255, 0.35));
  }

  .bolt__readout {
    font-family: var(--sl-font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.02em;
    color: var(--ly-spark);
    white-space: nowrap;
  }
  .bolt__readout b {
    font-weight: 500;
    color: var(--ly-spark);
  }

  /* --- Motion (opt-in) ------------------------------------------------ */
  @media (prefers-reduced-motion: no-preference) {
    .bolt__glow {
      animation: bolt-pulse 2.8s ease-in-out infinite;
    }
    @keyframes bolt-pulse {
      0%, 100% { opacity: 0.45; transform: translate(-50%, -50%) scale(0.9); }
      50% { opacity: 0.85; transform: translate(-50%, -50%) scale(1.08); }
    }

    /* A faint scan line sweeping down the input panel. */
    .panel--in::after {
      content: '';
      position: absolute;
      inset: 33px 0 auto 0; /* below the title bar */
      height: 40%;
      background: linear-gradient(
        to bottom,
        transparent,
        rgba(53, 224, 216, 0.09) 45%,
        transparent
      );
      pointer-events: none;
      animation: scan 5.5s cubic-bezier(0.4, 0, 0.6, 1) infinite;
    }
    @keyframes scan {
      0% { transform: translateY(-40%); opacity: 0; }
      15% { opacity: 1; }
      85% { opacity: 1; }
      100% { transform: translateY(230%); opacity: 0; }
    }
  }

  /* --- Stacked layout (mobile) --------------------------------------- */
  @media (max-width: 720px) {
    .trace {
      grid-template-columns: 1fr;
      justify-items: stretch;
      gap: 0.5rem;
    }
    .bolt {
      flex-direction: row;
      gap: 0.75rem;
      padding: 0.35rem 0;
    }
    .bolt__svg {
      transform: rotate(0deg); /* point downward for the vertical stack */
      width: 44px;
      height: 44px;
    }
    .bolt__glow {
      width: 90px;
      height: 90px;
    }
  }
</style>
