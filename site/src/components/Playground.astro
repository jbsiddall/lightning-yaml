---
// Playground.astro — the single, shared interactive comparison + benchmark
// widget. Rendered BOTH on the standalone /playground page and inlined on the
// homepage (Landing.astro), so the behaviour and look are identical in both
// places (DRY — one source of truth).
//
// On Run it loads the three real, published parsers (lightning-yaml, yaml,
// js-yaml) from jsDelivr and, on WHATEVER YAML/JSON is in the editor:
//   1. parses with all three — reporting errors and structural disagreement,
//      then times each parse; and
//   2. dumps the parsed value back with all three plus JSON.stringify, timing
//      each and checking it round-trips.
//
// Timing is a fair, best-effort in-browser microbenchmark: identical warmup,
// calibration and round count for every candidate, median reported. It is a
// single-machine, single-run indicator — NOT the rigorous CI benchmark on
// /benchmarks — and the panel says so. Nothing is tuned to flatter
// lightning-yaml; a competitor winning a row is shown exactly as measured.
//
// Self-contained styling: the component defines its own --pg-* tokens, deferring
// to the site's --ly-* brand tokens where they exist (Starlight pages) and
// falling back to the same hex on the raw /playground page — so it renders the
// same dark "instrument" either way. The client work is one `is:inline
// type="module"` script so Astro/Vite leaves the native CDN imports alone.
interface Props {
  /** When to first auto-run: on scroll-into-view (homepage) or immediately (dedicated page). */
  autorun?: 'view' | 'immediate' | 'none';
}
const { autorun = 'view' }: Props = Astro.props;
---

<section class="pg" data-autorun={autorun} aria-labelledby="pg-title">
  <header class="pg__intro">
    <span class="pg__eyebrow">Live playground</span>
    <h2 class="pg__title" id="pg-title">Help us break it</h2>
    <p class="pg__lede">
      Paste any YAML or JSON and hit <b>Run</b> — all three parsers race on your input
      in your browser, then dump it back and race again. If you find a case where
      <b>lightning-yaml</b> is slower, or disagrees with the others, you've found
      something we want to fix — the numbers are one click from a GitHub issue.
    </p>
  </header>

  <div class="pg__grid">
    <section class="pg__pane">
      <div class="pg__bar">
        <span class="pg__bar-title">Your YAML / JSON</span>
        <div class="pg__examples" id="pg-examples">
          <button type="button" data-ex="config">Config</button>
          <button type="button" data-ex="anchors">Anchors + binary</button>
          <button type="button" data-ex="merge">Merge keys</button>
          <button type="button" data-ex="json">JSON</button>
        </div>
      </div>
      <textarea id="pg-input" spellcheck="false" autocomplete="off" autocapitalize="off" aria-label="YAML or JSON input"></textarea>
      <div class="pg__actions">
        <button type="button" class="pg__run" id="pg-run">Run benchmark ▶</button>
        <span class="pg__runhint" id="pg-runhint"></span>
      </div>
    </section>

    <section class="pg__pane">
      <div class="pg__bar">
        <span class="pg__bar-title">Scoreboard</span>
        <span class="pg__bar-note" id="pg-status">Press Run to measure.</span>
      </div>
      <div class="pg__out" id="pg-out"></div>
    </section>
  </div>
</section>

<script is:inline type="module">
  const REPO = 'https://github.com/jbsiddall/lightning-yaml'
  const CDN = {
    'lightning-yaml': 'https://cdn.jsdelivr.net/npm/lightning-yaml/+esm',
    yaml: 'https://cdn.jsdelivr.net/npm/yaml/+esm',
    'js-yaml': 'https://cdn.jsdelivr.net/npm/js-yaml/+esm',
  }

  const EXAMPLES = {
    config:
      '# A typical config — all three parsers should agree\n' +
      'name: billing-service\n' +
      'replicas: 3\n' +
      'ports: [8080, 8443]\n' +
      'env:\n' +
      '  - name: LOG_LEVEL\n' +
      '    value: info\n' +
      'healthcheck:\n' +
      '  path: /healthz\n' +
      '  timeoutSeconds: 2\n' +
      'enabled: true\n' +
      'notes: null\n',
    anchors:
      '# Anchors & aliases (&/*) plus a !!binary blob\n' +
      'defaults: &defaults\n' +
      '  retries: 3\n' +
      '  timeout: 30\n' +
      'service_a:\n' +
      '  settings: *defaults\n' +
      '  name: a\n' +
      'logo: !!binary |\n' +
      '  R0lGODlhAQABAAAAACw=\n',
    merge:
      '# Merge keys (<<) are not in YAML 1.2 core, so all three parsers keep "<<"\n' +
      '# as a literal key by default. js-yaml merges it only with its opt-in\n' +
      '# YAML 1.1 schema (js-yaml 4 merged by default; v5 no longer does).\n' +
      'base: &base\n' +
      '  a: 1\n' +
      '  b: 2\n' +
      'derived:\n' +
      '  <<: *base\n' +
      '  b: 3\n',
    json: '{ "name": "lightning-yaml", "version": "0.1.0", "features": ["fast", "spec-compliant"], "deps": null }\n',
  }

  // One Playground per page, so a document-level lookup is safe (module scripts
  // don't set document.currentScript, so we can't scope from the script node).
  const root = document.querySelector('.pg')
  const inputEl = root.querySelector('#pg-input')
  const outEl = root.querySelector('#pg-out')
  const statusEl = root.querySelector('#pg-status')
  const runBtn = root.querySelector('#pg-run')
  const runHint = root.querySelector('#pg-runhint')

  // --- value classification & structural diff --------------------------------
  function isBytes(v) {
    return (
      v instanceof Uint8Array ||
      v instanceof ArrayBuffer ||
      (typeof Buffer !== 'undefined' && Buffer.isBuffer && Buffer.isBuffer(v))
    )
  }
  function toBytes(v) {
    return v instanceof ArrayBuffer ? new Uint8Array(v) : v
  }
  function kind(v) {
    if (v === undefined) return 'undefined'
    if (v === null) return 'null'
    if (Array.isArray(v)) return 'array'
    if (isBytes(v)) return 'bytes'
    if (v instanceof Map) return 'map'
    return typeof v
  }
  function asObj(v) {
    if (v instanceof Map) {
      const o = {}
      for (const [k, val] of v) o[String(k)] = val
      return o
    }
    return v
  }
  function diff(a, b, path) {
    path = path || '(root)'
    const ka = kind(a)
    const kb = kind(b)
    if (ka !== kb) return { path, a, b, reason: 'type ' + ka + ' vs ' + kb }
    switch (ka) {
      case 'bytes': {
        const A = toBytes(a)
        const B = toBytes(b)
        if (A.length !== B.length) return { path, a, b, reason: 'byte length ' + A.length + ' vs ' + B.length }
        for (let i = 0; i < A.length; i++)
          if (A[i] !== B[i]) return { path: path + '[byte ' + i + ']', a: A[i], b: B[i], reason: 'byte value' }
        return null
      }
      case 'array': {
        if (a.length !== b.length) return { path, a, b, reason: 'length ' + a.length + ' vs ' + b.length }
        for (let i = 0; i < a.length; i++) {
          const d = diff(a[i], b[i], path + '[' + i + ']')
          if (d) return d
        }
        return null
      }
      case 'map':
      case 'object': {
        const ao = asObj(a)
        const bo = asObj(b)
        const ak = Object.keys(ao)
        const bk = Object.keys(bo)
        for (const k of ak) if (!(k in bo)) return { path: path + '.' + k, a: ao[k], b: undefined, reason: 'key only in left' }
        for (const k of bk) if (!(k in ao)) return { path: path + '.' + k, a: undefined, b: bo[k], reason: 'key only in right' }
        for (const k of ak) {
          const d = diff(ao[k], bo[k], path + '.' + k)
          if (d) return d
        }
        return null
      }
      case 'number':
        if (Number.isNaN(a) && Number.isNaN(b)) return null
        return a === b ? null : { path, a, b, reason: 'number value' }
      default:
        return a === b ? null : { path, a, b, reason: ka + ' value' }
    }
  }
  function preview(v) {
    const k = kind(v)
    if (k === 'bytes') return 'bytes(' + toBytes(v).length + ')'
    if (k === 'array') return 'Array(' + v.length + ')'
    if (k === 'map') return 'Map(' + v.size + ')'
    if (k === 'object') {
      const ks = Object.keys(v)
      return '{ ' + ks.slice(0, 3).join(', ') + (ks.length > 3 ? ', …' : '') + ' }'
    }
    if (k === 'undefined') return '∅ (missing)'
    if (k === 'string') return JSON.stringify(v.length > 24 ? v.slice(0, 24) + '…' : v)
    return String(v)
  }
  function displayClone(v, seen) {
    seen = seen || new Set()
    const k = kind(v)
    if (k === 'bytes') {
      const b = toBytes(v)
      return 'Uint8Array(' + b.length + ') [' + Array.from(b).join(', ') + ']'
    }
    if (k === 'undefined') return '(undefined)'
    if (k === 'number' && !Number.isFinite(v)) return String(v)
    if (typeof v === 'bigint') return v.toString() + 'n'
    if (v === null || typeof v !== 'object') return v
    if (seen.has(v)) return '[Circular]'
    seen.add(v)
    let out
    if (Array.isArray(v)) out = v.map((x) => displayClone(x, seen))
    else {
      const src = asObj(v)
      out = {}
      for (const key of Object.keys(src)) out[key] = displayClone(src[key], seen)
    }
    seen.delete(v)
    return out
  }
  function safeStringify(v) {
    if (v === undefined) return '(undefined — empty document)'
    try {
      return JSON.stringify(displayClone(v), null, 2)
    } catch (e) {
      return String(v)
    }
  }
  function esc(s) {
    return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
  }

  // --- number formatting -----------------------------------------------------
  function fmtNs(ns) {
    if (!isFinite(ns)) return '—'
    if (ns >= 1e9) return (ns / 1e9).toFixed(2) + ' s'
    if (ns >= 1e6) return (ns / 1e6).toFixed(ns / 1e6 < 10 ? 2 : 1) + ' ms'
    if (ns >= 1e3) return (ns / 1e3).toFixed(ns / 1e3 < 10 ? 2 : 1) + ' µs'
    return Math.round(ns) + ' ns'
  }
  function fmtRatio(r) {
    if (!isFinite(r)) return ''
    return (r < 10 ? r.toFixed(1) : Math.round(r)) + '×'
  }

  // --- fair in-browser microbenchmark ----------------------------------------
  // Identical procedure for every candidate: warm the JIT, calibrate a batch
  // size that clears the timer's resolution, then take the MEDIAN of a fixed
  // number of batches (robust to GC pauses). Total wall-time per candidate is
  // capped so a giant input can't freeze the tab for long — when the cap trims
  // the round count, `reduced` is set and the panel flags lower confidence.
  const WARMUP_MS = 15
  const TARGET_BATCH_MS = 8
  const ROUNDS = 12
  const MAX_TOTAL_MS = 450

  function runN(fn, n) {
    const t0 = performance.now()
    for (let i = 0; i < n; i++) fn()
    return performance.now() - t0
  }
  async function measure(fn) {
    const warmStart = performance.now()
    do {
      fn()
    } while (performance.now() - warmStart < WARMUP_MS)

    let iters = 1
    for (;;) {
      const dt = runN(fn, iters)
      if (dt >= TARGET_BATCH_MS || iters >= 5e6) break
      const factor = dt > 0 ? Math.max(2, Math.ceil(TARGET_BATCH_MS / dt)) : 8
      iters = Math.min(iters * factor, 5e6)
    }

    const samples = []
    const startAll = performance.now()
    let reduced = false
    for (let r = 0; r < ROUNDS; r++) {
      const dt = runN(fn, iters)
      samples.push((dt * 1e6) / iters)
      if (performance.now() - startAll > MAX_TOTAL_MS) {
        reduced = r < ROUNDS - 1
        break
      }
    }
    samples.sort((a, b) => a - b)
    return { median: samples[Math.floor(samples.length / 2)], rounds: samples.length, reduced }
  }

  // --- parsers (lazy, from the CDN) ------------------------------------------
  let ops = null
  let booting = null
  function boot() {
    if (booting) return booting
    booting = (async () => {
      const ids = Object.keys(CDN)
      const settled = await Promise.allSettled(ids.map((id) => import(CDN[id])))
      const mods = {}
      const loadErr = {}
      settled.forEach((res, i) => {
        if (res.status === 'fulfilled') mods[ids[i]] = res.value
        else loadErr[ids[i]] = (res.reason && res.reason.message) || 'failed to load from CDN'
      })
      const jsy = mods['js-yaml']
      const jsyLoad = jsy && (jsy.load || (jsy.default && jsy.default.load))
      const jsyDump = jsy && (jsy.dump || (jsy.default && jsy.default.dump))
      const ly = mods['lightning-yaml']
      const ym = mods['yaml']

      ops = {
        parse: [
          { id: 'lightning-yaml', self: true, fn: ly ? (t) => ly.parse(t) : null, loadError: loadErr['lightning-yaml'] },
          { id: 'yaml', fn: ym ? (t) => ym.parse(t, { maxAliasCount: -1 }) : null, loadError: loadErr['yaml'] },
          { id: 'js-yaml', fn: jsyLoad ? (t) => jsyLoad(t) : null, loadError: loadErr['js-yaml'] },
          // JSON.parse only joins the parse race when the input actually IS JSON
          // (a JSON test case). `optional` means: if it throws, drop it silently
          // rather than showing a bogus error row on ordinary YAML.
          { id: 'JSON', baseline: true, optional: true, fn: (t) => JSON.parse(t) },
        ],
        dump: [
          { id: 'lightning-yaml', self: true, fn: ly ? (v) => ly.stringify(v) : null, reparse: ly ? (t) => ly.parse(t) : null, loadError: loadErr['lightning-yaml'] },
          { id: 'yaml', fn: ym ? (v) => ym.stringify(v) : null, reparse: ym ? (t) => ym.parse(t, { maxAliasCount: -1 }) : null, loadError: loadErr['yaml'] },
          { id: 'js-yaml', fn: jsyDump ? (v) => jsyDump(v) : null, reparse: jsyLoad ? (t) => jsyLoad(t) : null, loadError: loadErr['js-yaml'] },
          { id: 'JSON', baseline: true, fn: (v) => JSON.stringify(v), reparse: (t) => JSON.parse(t) },
        ],
      }
    })()
    return booting
  }
  const yieldToUI = () => new Promise((r) => setTimeout(r, 0))
  function firstLine(e) {
    return (e && e.message ? e.message : String(e)).split('\n')[0]
  }

  // --- the run ---------------------------------------------------------------
  let lastReport = null
  async function run() {
    runBtn.disabled = true
    runBtn.textContent = 'Loading…'
    setStale(false)
    statusEl.textContent = 'Loading parsers…'
    await boot()

    const text = inputEl.value
    runBtn.textContent = 'Running…'
    statusEl.textContent = 'Measuring…'
    await yieldToUI()

    const parseRows = []
    for (const p of ops.parse) {
      if (!p.fn) {
        parseRows.push({ id: p.id, self: p.self, state: 'loaderror', error: p.loadError })
        continue
      }
      let value, err
      try {
        value = p.fn(text)
      } catch (e) {
        err = firstLine(e)
      }
      if (err !== undefined) {
        if (p.optional) continue // JSON.parse on non-JSON input — drop, don't flag.
        parseRows.push({ id: p.id, self: p.self, state: 'error', error: err })
        continue
      }
      const t = await measure(() => p.fn(text))
      parseRows.push({ id: p.id, self: p.self, baseline: p.baseline, state: 'ok', value, median: t.median, reduced: t.reduced })
      await yieldToUI()
    }

    const okParse = parseRows.filter((r) => r.state === 'ok')
    const clusters = []
    for (const r of okParse) {
      const c = clusters.find((cl) => diff(cl[0].value, r.value) === null)
      if (c) c.push(r)
      else clusters.push([r])
    }
    clusters.sort((a, b) => b.length - a.length)
    const majority = clusters[0] || []
    const allAgree = okParse.length >= 2 && clusters.length === 1
    for (const r of parseRows) {
      if (r.state !== 'ok') { r.agree = null; continue }
      if (okParse.length < 2) r.agree = 'solo'
      else r.agree = majority.indexOf(r) !== -1 ? (allAgree ? 'agree' : 'majority') : 'differs'
    }

    const diffs = []
    const lyOk = parseRows.find((r) => r.id === 'lightning-yaml' && r.state === 'ok')
    if (lyOk) {
      for (const r of okParse) {
        if (r === lyOk) continue
        const d = diff(lyOk.value, r.value)
        if (d) diffs.push({ a: 'lightning-yaml', b: r.id, d })
      }
    } else if (okParse.length === 2) {
      const d = diff(okParse[0].value, okParse[1].value)
      if (d) diffs.push({ a: okParse[0].id, b: okParse[1].id, d })
    }

    const source = lyOk ? lyOk.value : okParse[0] ? okParse[0].value : undefined
    const dumpRows = []
    if (source !== undefined) {
      for (const d of ops.dump) {
        if (!d.fn) {
          dumpRows.push({ id: d.id, self: d.self, baseline: d.baseline, state: 'loaderror', error: d.loadError })
          continue
        }
        let output, err
        try {
          output = d.fn(source)
        } catch (e) {
          err = firstLine(e)
        }
        if (err !== undefined) {
          dumpRows.push({ id: d.id, self: d.self, baseline: d.baseline, state: 'error', error: err })
          continue
        }
        let roundtrip = 'unknown'
        if (d.reparse) {
          try {
            roundtrip = diff(source, d.reparse(output)) === null ? 'ok' : 'diverges'
          } catch (e) {
            roundtrip = 'threw'
          }
        }
        const t = await measure(() => d.fn(source))
        dumpRows.push({ id: d.id, self: d.self, baseline: d.baseline, state: 'ok', median: t.median, reduced: t.reduced, roundtrip })
        await yieldToUI()
      }
    }

    lastReport = { text, parseRows, dumpRows, diffs, allAgree, okParseCount: okParse.length, source }
    render(lastReport)
    runBtn.disabled = false
    runBtn.textContent = 'Run benchmark ▶'
  }

  // --- rendering -------------------------------------------------------------
  const nm = (id, self) => (self ? '<b>' + esc(id) + '</b>' : esc(id))
  function fastest(rows) {
    let min = Infinity
    for (const r of rows) if (r.state === 'ok' && r.median < min) min = r.median
    return min
  }
  function timeCell(r, min) {
    if (r.state === 'loaderror') return '<span class="pg-x">CDN load failed</span>'
    if (r.state === 'error') return '<span class="pg-x">parse error</span>'
    const ratio = r.median > 0 && isFinite(min) ? r.median / min : Infinity
    const isBest = r.median <= min * 1.0001
    const rat = isBest ? '<span class="pg-best">1.0×</span>' : '<span class="pg-rat">' + esc(fmtRatio(ratio)) + '</span>'
    const flag = r.reduced ? '<span class="pg-approx" title="fewer samples — large input">≈</span>' : ''
    return '<span class="pg-ns">' + esc(fmtNs(r.median)) + '</span> ' + rat + flag
  }
  function dot(cls, label) {
    return '<span class="pg-dot pg-dot--' + cls + '"></span>' + label
  }
  function agreeCell(r) {
    if (r.state === 'loaderror') return dot('x', 'load failed')
    if (r.state === 'error') return dot('x', esc(r.error))
    if (r.agree === 'agree') return dot('ok', 'agrees')
    if (r.agree === 'majority') return dot('ok', 'agrees (majority)')
    if (r.agree === 'differs') return dot('warn', 'differs')
    return dot('ok', 'parsed')
  }
  function rtCell(r) {
    if (r.state === 'loaderror') return dot('x', 'load failed')
    if (r.state === 'error') return dot('x', esc(r.error))
    if (r.roundtrip === 'ok') return dot('ok', 'round-trips')
    if (r.roundtrip === 'diverges') return dot('warn', 'diverges')
    if (r.roundtrip === 'threw') return dot('x', 'reparse threw')
    return dot('muted', '—')
  }

  function render(rep) {
    const pMin = fastest(rep.parseRows)
    const dMin = fastest(rep.dumpRows)

    const pBody = rep.parseRows
      .map(
        (r) =>
          '<tr' + (r.self ? ' class="pg-self"' : '') + '><td class="pg-lib">' + nm(r.id, r.self) + (r.baseline ? '<span class="pg-base">baseline</span>' : '') + '</td>' +
          '<td class="pg-num">' + timeCell(r, pMin) + '</td>' +
          '<td class="pg-stat">' + agreeCell(r) + '</td></tr>',
      )
      .join('')

    const dBody = rep.dumpRows
      .map(
        (r) =>
          '<tr' + (r.self ? ' class="pg-self"' : '') + '><td class="pg-lib">' + nm(r.id, r.self) + (r.baseline ? '<span class="pg-base">baseline</span>' : '') + '</td>' +
          '<td class="pg-num">' + timeCell(r, dMin) + '</td>' +
          '<td class="pg-stat">' + rtCell(r) + '</td></tr>',
      )
      .join('')

    const diffHtml = rep.diffs.length
      ? '<div class="pg-diffs">' +
        rep.diffs
          .map(
            (x) =>
              '<div class="pg-diff">' + nm(x.a, x.a === 'lightning-yaml') + ' ⟷ ' + nm(x.b, x.b === 'lightning-yaml') +
              ' at <span class="pg-path">' + esc(x.d.path) + '</span>: ' + esc(preview(x.d.a)) + ' vs ' + esc(preview(x.d.b)) +
              ' <span class="pg-reason">(' + esc(x.d.reason) + ')</span></div>',
          )
          .join('') +
        '</div>'
      : ''

    const dumpSection = rep.dumpRows.length
      ? '<div class="pg-tabhead">Stringify — dump the parsed value back <span class="pg-th-sub">median ns/op · round-trip</span></div>' +
        '<table class="pg-table"><tbody>' + dBody + '</tbody></table>'
      : '<p class="pg-empty">No parser produced a value to dump.</p>'

    const valueSection =
      rep.source !== undefined
        ? '<details class="pg-details"><summary>parsed value (lightning-yaml)</summary><pre class="pg-pre">' +
          esc(safeStringify(rep.source)) + '</pre></details>'
        : ''

    outEl.innerHTML =
      '<div class="pg-tabhead">Parse <span class="pg-th-sub">median ns/op · agreement</span></div>' +
      '<table class="pg-table"><tbody>' + pBody + '</tbody></table>' +
      diffHtml +
      dumpSection +
      valueSection +
      '<a class="pg-issue" id="pg-issue" target="_blank" rel="noopener">Open a GitHub issue with these results&nbsp;→</a>' +
      '<p class="pg-note">Measured live in <em>your</em> browser: identical warmup + median-of-' + ROUNDS +
      ' for every library — indicative only, not the CI benchmark on the ' +
      '<a href="/benchmarks/">Benchmarks page</a>. Values compared structurally; <code>!!binary</code> ' +
      'normalizes to bytes, <code>yaml</code> runs with <code>maxAliasCount:-1</code>. A disagreement is ' +
      'not automatically a bug — the YAML&nbsp;1.2 spec adjudicates.</p>'

    root.querySelector('#pg-issue').href = issueUrl(rep)

    let msg
    if (rep.okParseCount < 2) msg = 'Only one parser produced a value.'
    else if (rep.allAgree) msg = '✓ All parsers agree.'
    else msg = '⚠ Parsers disagree — see below.'
    statusEl.textContent = msg
  }

  // --- prefilled GitHub issue ------------------------------------------------
  // Deep-links to the "Playground report" issue *form*. Blank issues are disabled
  // (.github/ISSUE_TEMPLATE/config.yml), so a free-form ?body= link only strands
  // the user on the template chooser and drops the prefill — the form does not.
  // The query-param names below MUST match the field ids in
  // .github/ISSUE_TEMPLATE/playground_report.yml.
  function issueUrl(rep) {
    // Baseline rows (native JSON) are excluded: beating JSON.parse is the design
    // target, not a race we claim to win — "slower" means slower than a YAML library.
    const slower = (rows) => {
      const ly = rows.find((r) => r.id === 'lightning-yaml' && r.state === 'ok')
      if (!ly) return false
      return rows.some((r) => r.state === 'ok' && !r.self && !r.baseline && r.median < ly.median)
    }
    const hasDivergence = rep.diffs.length > 0 || rep.dumpRows.some((r) => r.roundtrip === 'diverges')
    const lySlower = slower(rep.parseRows) || slower(rep.dumpRows)
    let title
    if (hasDivergence) title = 'Playground: parser divergence on this input'
    else if (lySlower) title = 'Playground: lightning-yaml is slower on this input'
    else title = 'Playground: benchmark result'

    const mdTime = (r) => (r.state === 'ok' ? fmtNs(r.median) : r.state === 'error' ? 'error' : 'load failed')
    const pTable =
      '| library | parse ns/op | agreement |\n|---|---|---|\n' +
      rep.parseRows.map((r) => '| ' + r.id + ' | ' + mdTime(r) + ' | ' + (r.state === 'ok' ? r.agree || 'parsed' : r.state) + ' |').join('\n')
    const dTable =
      '| library | stringify ns/op | round-trip |\n|---|---|---|\n' +
      rep.dumpRows.map((r) => '| ' + r.id + ' | ' + mdTime(r) + ' | ' + (r.state === 'ok' ? r.roundtrip : r.state) + ' |').join('\n')

    const notes = hasDivergence
      ? 'Parsers disagree on this input — see the agreement column above.'
      : lySlower
        ? 'lightning-yaml was slower than another parser here.'
        : ''
    const runtime = typeof navigator !== 'undefined' ? navigator.userAgent : ''

    // Give the input whatever room the (small, bounded) other fields leave —
    // GitHub truncates very long prefills.
    const budget = 6000
    const spent = title.length + pTable.length + dTable.length + notes.length + runtime.length
    let yaml = rep.text
    const room = budget - spent
    if (yaml.length > room) yaml = yaml.slice(0, Math.max(0, room - 40)) + '\n# … truncated for the issue link …'

    // %20-encode (encodeURIComponent), not URLSearchParams' "+", so spaces in the
    // YAML survive GitHub's decoder and the input's indentation isn't corrupted.
    const params = [
      ['template', 'playground_report.yml'],
      ['title', title],
      ['input', yaml],
      ['parse', pTable],
      ['stringify', dTable],
      ['runtime', runtime],
      ['notes', notes],
    ]
    return REPO + '/issues/new?' + params.filter(([, v]) => v !== '').map(([k, v]) => k + '=' + encodeURIComponent(v)).join('&')
  }

  // --- staleness + wiring ----------------------------------------------------
  function setStale(on) {
    if (on) {
      outEl.classList.add('pg-stale')
      runHint.textContent = 'input changed — Run again'
    } else {
      outEl.classList.remove('pg-stale')
      runHint.textContent = ''
    }
  }
  inputEl.addEventListener('input', () => {
    if (lastReport) setStale(true)
  })
  runBtn.addEventListener('click', () => run())
  root.querySelector('#pg-examples').addEventListener('click', (e) => {
    const btn = e.target.closest('button[data-ex]')
    if (!btn) return
    inputEl.value = EXAMPLES[btn.dataset.ex] || ''
    run()
  })

  inputEl.value = EXAMPLES.config

  let started = false
  const kick = () => {
    if (started) return
    started = true
    run()
  }
  const mode = root.dataset.autorun
  if (mode === 'immediate') {
    kick()
  } else if (mode === 'view' && 'IntersectionObserver' in window) {
    const io = new IntersectionObserver(
      (entries) => {
        for (const en of entries) {
          if (en.isIntersecting) {
            io.disconnect()
            kick()
          }
        }
      },
      { rootMargin: '120px' },
    )
    io.observe(outEl)
  } else if (mode !== 'none') {
    kick()
  }
</script>

