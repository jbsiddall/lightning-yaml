---
// Stats.astro — honest headline numbers from the repo README.
// Big mono figures on dark instrument cards.
// Provenance pins (issue #30): js-yaml:5.2.1 yaml:2.9.0 ly:83b1dd0
const stats = [
  { n: '4.4×', accent: 'charge', label: 'faster than js-yaml', sub: 'block-YAML parse' },
  { n: '39×', accent: 'spark', label: 'faster than  yaml ', sub: 'block-YAML parse' },
  { n: '97.6%', accent: 'charge', label: 'YAML Test Suite pass', sub: 'js-yaml 94.9% · yaml 97.1%' },
  { n: '≈1.3×', accent: 'spark', label: 'of JSON.parse memory', sub: 'peak RSS, 10 MB fixture' },
];
---

<section class="stats" aria-label="Benchmark highlights">
  {stats.map((s) => (
    <div class="stat">
      <div class:list={['stat__n', `stat__n--${s.accent}`]}>{s.n}</div>
      <div class="stat__label">{s.label}</div>
      <div class="stat__sub">{s.sub}</div>
    </div>
  ))}
</section>

<style>
  .stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: clamp(0.6rem, 1.6vw, 1rem);
    width: 100%;
  }

  .stat {
    padding: 1.15rem 1.15rem 1.05rem;
    border: 1px solid var(--ly-line);
    border-radius: 12px;
    background: var(--ly-panel);
    box-shadow: 0 14px 34px -26px rgba(0, 0, 0, 0.9);
  }

  .stat__n {
    font-family: var(--sl-font-mono);
    font-size: clamp(1.9rem, 4.4vw, 2.55rem);
    font-weight: 500;
    line-height: 1;
    letter-spacing: -0.01em;
  }
  .stat__n--charge {
    color: var(--ly-charge);
    text-shadow: 0 0 22px rgba(124, 92, 255, 0.35);
  }
  .stat__n--spark {
    color: var(--ly-spark);
    text-shadow: 0 0 22px rgba(53, 224, 216, 0.3);
  }

  .stat__label {
    margin-top: 0.7rem;
    color: var(--ly-ink);
    font-size: 0.92rem;
    font-weight: 600;
  }
  .stat__sub {
    margin-top: 0.2rem;
    color: var(--ly-muted);
    font-family: var(--sl-font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.01em;
  }

  @media (max-width: 860px) {
    .stats { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 460px) {
    .stats { grid-template-columns: 1fr; }
  }
</style>
