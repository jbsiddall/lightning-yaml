---
// Generated table of every research note carrying an `optimization` block. Data lives in the
// note front matter (schema in src/content.config.ts), so this table can never drift from the notes.
import { getCollection } from 'astro:content'

const RANK: Record<string, number> = { promising: 0, situational: 1, inconclusive: 2, 'not-worth-it': 3 }
const LABEL: Record<string, string> = {
  promising: 'Promising',
  situational: 'Situational',
  inconclusive: 'Inconclusive',
  'not-worth-it': 'Not worth it',
}

const rows = (await getCollection('docs', ({ data }) => Boolean(data.optimization)))
  .map((e) => ({ id: e.id, opt: e.data.optimization! }))
  .sort((a, b) => RANK[a.opt.verdict] - RANK[b.opt.verdict] || a.opt.name.localeCompare(b.opt.name))

// Base-aware so links resolve under the GitHub-Pages fallback (PAGES_BASE=/lightning-yaml) too.
const base = import.meta.env.BASE_URL.replace(/\/$/, '')
const href = (id: string) => `${base}/${id}/`
---

<div class="opt-index-scroll">
  <table class="opt-index">
    <thead>
      <tr><th>Optimization</th><th>Conclusion</th><th>Verdict</th></tr>
    </thead>
    <tbody>
      {rows.map((r) => (
        <tr>
          <td><a href={href(r.id)}>{r.opt.name}</a></td>
          <td>{r.opt.conclusion}</td>
          <td><span class={`verdict verdict--${r.opt.verdict}`}>{LABEL[r.opt.verdict] ?? r.opt.verdict}</span></td>
        </tr>
      ))}
    </tbody>
  </table>
</div>

<style>
  .opt-index-scroll { overflow-x: auto; }
  .opt-index { width: 100%; border-collapse: collapse; margin: 0; }
  .opt-index th,
  .opt-index td { text-align: left; vertical-align: top; padding: 0.55rem 0.65rem; border-bottom: 1px solid var(--sl-color-gray-5); }
  .opt-index th { font-size: var(--sl-text-sm); }
  .opt-index td:first-child { white-space: nowrap; font-weight: 600; }
  .verdict {
    display: inline-block;
    white-space: nowrap;
    font-size: var(--sl-text-xs);
    font-weight: 600;
    padding: 0.05rem 0.55rem;
    border-radius: 999px;
    border: 1px solid currentColor;
  }
  .verdict--promising { color: var(--sl-color-green); }
  .verdict--situational { color: var(--sl-color-blue); }
  .verdict--inconclusive { color: var(--sl-color-gray-2); }
  .verdict--not-worth-it { color: var(--sl-color-orange); }
</style>
